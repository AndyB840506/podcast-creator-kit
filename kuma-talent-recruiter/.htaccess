Options -Indexes
ServerSignature Off

# Protect sensitive files from direct access
<FilesMatch "^(config\.php|composer\.json|composer\.lock)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Block direct access to reports directory
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^reports/ - [F,L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Disable Gzip/deflate for SSE streaming endpoint
<IfModule mod_deflate.c>
    SetEnvIf Request_URI "api/message\.php$" no-gzip dont-vary
</IfModule>

# PHP settings for streaming
<IfModule mod_php.c>
    php_value output_buffering Off
    php_value zlib.output_compression Off
</IfModule>
